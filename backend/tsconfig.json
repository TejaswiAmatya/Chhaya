{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "files": ["types/express.d.ts"],
  "include": ["prisma.config.ts", "index.ts", "app.ts", "routes/**/*", "controller/**/*", "middleware/**/*", "lib/**/*"],
  "exclude": ["node_modules", "dist"]
}
